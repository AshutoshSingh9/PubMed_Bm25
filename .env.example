# Clinical Intelligence System - Environment Variables
# ====================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- NCBI / PubMed Configuration ---
# Required for PubMed retrieval. Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_EMAIL=your.email@example.com
# Optional: Get an API key for higher rate limits (10 req/sec vs 3 req/sec)
# Register at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# --- Ollama Configuration ---
# Base URL for the Ollama server (default: local)
OLLAMA_BASE_URL=http://localhost:11434
# Model to use for clinical reasoning (must be pulled first: ollama pull llama3.1)
OLLAMA_MODEL=llama3.1

# --- Groq Configuration ---
# Set LLM_PROVIDER to 'groq' to use Groq instead of local Ollama
LLM_PROVIDER=groq
# Your Groq API Key (get one at: https://console.groq.com/keys)
GROQ_API_KEY=
# Groq Model to use
GROQ_MODEL=llama3-70b-8192

# --- Embedding Model ---
# HuggingFace model for biomedical embeddings (downloaded automatically on first run)
EMBEDDING_MODEL=menadsa/S-Bio_ClinicalBERT
# Fallback model if clinical model fails to load
EMBEDDING_FALLBACK_MODEL=all-MiniLM-L6-v2

# --- ChromaDB ---
# Directory for persistent vector storage
CHROMA_PERSIST_DIR=./chroma_db
# Collection name for clinical documents
CHROMA_COLLECTION=clinical_documents

# --- Pipeline Settings ---
# LLM temperature for clinical reasoning (lower = more deterministic)
LLM_TEMPERATURE=0.2
# Maximum tokens for LLM response
LLM_MAX_TOKENS=4096
# Number of retrieved documents to include as context
RAG_TOP_K=5
# BM25 vs Semantic weight (0.0 = full semantic, 1.0 = full BM25)
HYBRID_ALPHA=0.4
